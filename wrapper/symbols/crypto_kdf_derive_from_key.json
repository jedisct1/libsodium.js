{
  "name": "crypto_kdf_derive_from_key",
  "type": "function",
  "inputs": [
    {
      "name": "subkey_len",
      "type": "ranged_uint",
      "min_value": "libsodium._crypto_kdf_bytes_min()",
      "max_value": "libsodium._crypto_kdf_bytes_max()"
    },
    {
      "name": "subkey_id",
      "type": "u64"
    },
    {
      "name": "ctx",
      "type": "string",
      "length": "libsodium._crypto_kdf_contextbytes()"
    },
    {
      "name": "key",
      "type": "buf",
      "length": "libsodium._crypto_kdf_keybytes()"
    }
  ],
  "outputs": [
    {
      "name": "subkey",
      "length": "subkey_len",
      "type": "buf"
    }
  ],
  "target": "libsodium._crypto_kdf_derive_from_key(subkey_address, subkey_len, subkey_id_lo, subkey_id_hi, ctx_address, key_address) | 0",
  "assert_retval": [
    {
      "condition": "=== 0",
      "or_else_throw": "invalid subkey length"
    }
  ],
  "return": "_format_output(subkey, outputFormat)"
}
